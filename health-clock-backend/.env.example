# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Supabase Dashboard -> Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# 阿里云号码认证服务（Dypnsapi），用于手机号短信验证码登录
# 控制台: https://dypns.console.aliyun.com/
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
# 已审核通过的短信签名（例如「健康时钟」）
ALIYUN_SMS_SIGN_NAME=
# 短信模板 Code（模板正文建议使用占位符 ${code}，例如：您的验证码为 ${code}，5 分钟内有效。）
ALIYUN_SMS_TEMPLATE_CODE=
# 可选：号码认证方案名 SchemeName；未创建方案可留空
ALIYUN_SMS_SCHEME_NAME=
# 可选：Dypnsapi Endpoint，默认 dypnsapi.aliyuncs.com
ALIYUN_DYPNSAPI_ENDPOINT=dypnsapi.aliyuncs.com

# Cloudflare R2
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=health-clock-files
R2_ENDPOINT_URL=your_r2_endpoint_url
R2_PUBLIC_URL=your_r2_public_url

# AI Service (Dashscope)
AI_API_KEY=your_dashscope_api_key
AI_MODEL_PROVIDER=dashscope
AI_MODEL_NAME=qwen-plus

# OCR Service (Baidu)
BAIDU_OCR_API_KEY=your_baidu_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_secret_key

# App Config
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
